{
  "name": "safi-image",
  "version": "0.1.0",
  "description": "Pure TypeScript image manipulation for Node and Bun. No native binaries, no compile step.",
  "keywords": [
    "image",
    "image-processing",
    "image-manipulation",
    "resize",
    "crop",
    "rotate",
    "thumbnail",
    "png",
    "jpeg",
    "jpg",
    "webp",
    "gif",
    "bmp",
    "tiff",
    "exif",
    "typescript",
    "pure-js",
    "no-native",
    "zero-dependency",
    "bun",
    "obsidian"
  ],
  "license": "MIT",
  "author": "Abdulkader Safi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abdulkader-Safi/safi-image.git"
  },
  "homepage": "https://github.com/Abdulkader-Safi/safi-image#readme",
  "bugs": {
    "url": "https://github.com/Abdulkader-Safi/safi-image/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "node --experimental-test-module-mocks --test 'test/**/*.test.ts'",
    "test:bun": "bun run test/smoke.bun.ts",
    "check:guards": "node scripts/guards.mjs",
    "check:size": "node scripts/size.mjs",
    "check": "tsc -p tsconfig.test.json && node scripts/guards.mjs && node --experimental-test-module-mocks --test 'test/**/*.test.ts'",
    "gen:wasm": "node scripts/gen-wasm.mjs",
    "bench:preview": "node --experimental-strip-types --no-warnings scripts/bench-preview.mjs",
    "example": "node --experimental-strip-types --no-warnings examples/tour.ts",
    "example:preview": "node --experimental-strip-types --no-warnings examples/preview.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.2",
    "exifr": "^7.1.3",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@jsquash/webp": "^1.5.0"
  }
}
